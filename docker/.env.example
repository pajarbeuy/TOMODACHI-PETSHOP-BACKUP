# Docker Compose variables
APP_KEY=base64:generate-with-php-artisan-key-generate-show
DB_ROOT_PASSWORD=change-this-root-password
DB_DATABASE=tomodachi_petshop
DB_USERNAME=tomodachi_user
DB_PASSWORD=change-this-db-password
NGINX_PORT=80
API_BASE_URL=/

# Docker Hub images for production compose
BACKEND_IMAGE=dockerhubusername/tomodachi-backend:latest
FRONTEND_IMAGE=dockerhubusername/tomodachi-frontend:latest

# Laravel container env template
APP_NAME="Tomodachi Pet Shop"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tomodachi-petshop.xyz

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=replace-with-your-midtrans-server-key
MIDTRANS_CLIENT_KEY=replace-with-your-midtrans-client-key
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-20b:free,openai/gpt-oss-120b:free,nex-agi/nex-n2-pro:free,nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_TIMEOUT=60
