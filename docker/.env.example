# Docker Compose variables
APP_KEY=base64:generate-with-php-artisan-key-generate-show
DB_ROOT_PASSWORD=change-this-root-password
DB_DATABASE=tomodachi_petshop
DB_USERNAME=tomodachi_user
DB_PASSWORD=change-this-db-password
NGINX_PORT=80

# Docker Hub images for production compose
BACKEND_IMAGE=dockerhubusername/tomodachi-backend:latest
FRONTEND_IMAGE=dockerhubusername/tomodachi-frontend:latest

# Laravel container env template
APP_NAME="Tomodachi Pet Shop"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.example

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=replace-with-your-midtrans-server-key
MIDTRANS_CLIENT_KEY=replace-with-your-midtrans-client-key
