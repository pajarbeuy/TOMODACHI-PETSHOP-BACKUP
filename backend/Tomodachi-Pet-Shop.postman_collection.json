                  "    pm.expect(jsonData.data).to.have.keys('kpi', 'sales_trend', 'top_products', 'category_breakdown');",
                  "    ",
                  "    var kpi = jsonData.data.kpi;",
                  "    pm.expect(kpi).to.have.all.keys('today_sales', 'total_transactions_today', 'items_sold_today', 'average_transaction_value', 'yesterday_sales', 'transactions_yesterday', 'today_sales_change_percent', 'transactions_change', 'monthly_revenue', 'previous_monthly_revenue', 'monthly_revenue_change_percent', 'active_products', 'low_stock_products');",
                  "});",
                  "",
                  "pm.test('✅ Sales trend has 7 days of data', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.sales_trend).to.be.an('array');",
                  "    pm.expect(jsonData.data.sales_trend.length).to.equal(7);",
                  "});",
                  "",
                  "pm.test('✅ Category breakdown has percentage data', function() {",
                  "    var jsonData = pm.response.json();",
                  "    var breakdown = jsonData.data.category_breakdown;",
                  "    pm.expect(breakdown).to.be.an('object');",
                  "    ",
                  "    var total = Object.values(breakdown).reduce((sum, val) => sum + val, 0);",
                  "    if (total > 0) {",
                  "        pm.expect(Math.round(total)).to.equal(100);",
                  "    }",
                  "});",
                  "",
                  "console.log('📊 Dashboard Analytics - Today Sales: ' + pm.response.json().data.kpi.today_sales);",
                  "console.log('📈 Sales Change: ' + pm.response.json().data.kpi.today_sales_change_percent + '%');",
                  "console.log('⚠️ Low Stock Products: ' + pm.response.json().data.kpi.low_stock_products);",
                  "console.log('🎯 Top Product: ' + pm.response.json().data.top_products[0]?.product_name);"
                ],
                "type": "text/javascript"
              }
            }
