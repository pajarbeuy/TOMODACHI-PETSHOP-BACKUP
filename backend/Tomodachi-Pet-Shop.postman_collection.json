        {
          "name": "Get Top Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status Code: 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('✅ Response returns ranked products array', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal(true);",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('✅ Top products are properly ranked and sorted', function() {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 0) {",
                  "        var item = jsonData.data[0];",
                  "        pm.expect(item).to.have.keys('rank', 'product_id', 'product_name', 'sku', 'quantity_sold', 'total_revenue');",
                  "        pm.expect(item.rank).to.equal(1);",
                  "        pm.expect(item.quantity_sold).to.be.a('number');",
                  "        pm.expect(item.total_revenue).to.be.a('number');",
                  "    }",
                  "});",
                  "",
                  "pm.test('✅ Ranking is sequential and correct', function() {",
                  "    var jsonData = pm.response.json();",
                  "    var limit = 5;",
                  "    for (var i = 0; i < Math.min(limit, jsonData.data.length); i++) {",
                  "        pm.expect(jsonData.data[i].rank).to.equal(i + 1);",
                  "    }",
                  "});",
                  "",
                  "console.log('🏆 Top Products - Count: ' + pm.response.json().data.length);",
                  "if (pm.response.json().data.length > 0) console.log('⭐ #1 Product: ' + pm.response.json().data[0].product_name + ' (' + pm.response.json().data[0].quantity_sold + ' sold)');"
                ],
                "type": "text/javascript"
              }
            }
          ],
