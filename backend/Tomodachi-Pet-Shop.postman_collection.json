    {
      "name": "Reports & Dashboard",
      "item": [
        {
          "name": "Get Sales Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status Code: 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('✅ Response has valid structure', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal(true);",
                  "    pm.expect(jsonData.data).to.have.all.keys('period', 'summary', 'by_channel');",
                  "});",
                  "",
                  "pm.test('✅ Summary contains required fields', function() {",
                  "    var jsonData = pm.response.json();",
                  "    var summary = jsonData.data.summary;",
                  "    pm.expect(summary).to.have.all.keys('total_transactions', 'total_revenue', 'total_items_sold', 'average_transaction_value');",
                  "    pm.expect(summary.total_transactions).to.be.a('number');",
                  "    pm.expect(summary.total_revenue).to.be.a('number');",
                  "    pm.expect(summary.total_items_sold).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('✅ Channel breakdown includes offline & online', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.by_channel).to.have.keys('offline', 'online');",
                  "    pm.expect(jsonData.data.by_channel.offline.total_transactions).to.be.a('number');",
                  "    pm.expect(jsonData.data.by_channel.online.total_revenue).to.be.a('number');",
                  "});",
                  "",
                  "console.log('📊 Sales Report - Total Revenue: ' + pm.response.json().data.summary.total_revenue);",
                  "console.log('🎫 Transactions Count: ' + pm.response.json().data.summary.total_transactions);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/reports/sales?start_date=2026-06-01&end_date=2026-06-18&channel=all",
              "host": ["{{base_url}}"],
              "path": ["api", "reports", "sales"],
              "query": [
                {
                  "key": "start_date",
                  "value": "2026-06-01"
                },
                {
                  "key": "end_date",
                  "value": "2026-06-18"
                },
                {
                  "key": "channel",
                  "value": "all"
                },
                {
                  "key": "category",
                  "value": "cat",
                  "disabled": true
                }
              ]
            },
            "description": "Laporan penjualan berdasarkan periode dan channel (Owner only)"
          },
          "response": []
        },
        {
          "name": "Get Sales Summary",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✅ Status Code: 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('✅ Response returns array of daily summaries', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.equal(true);",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('✅ Each summary item has required fields', function() {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.length > 0) {",
                  "        var item = jsonData.data[0];",
                  "        pm.expect(item).to.have.keys('date', 'total_revenue', 'transaction_count', 'items_sold');",
                  "        pm.expect(item.date).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
                  "        pm.expect(item.total_revenue).to.be.a('number');",
                  "        pm.expect(item.transaction_count).to.be.a('number');",
                  "    }",
                  "});",
                  "",
                  "console.log('📈 Sales Summary - Total entries: ' + pm.response.json().data.length);",
                  "if (pm.response.json().data.length > 0) console.log('💰 Latest revenue: ' + pm.response.json().data[0].total_revenue);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
